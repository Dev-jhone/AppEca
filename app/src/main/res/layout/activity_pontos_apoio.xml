<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pontos_apoio_titulo"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary_dark"
            android:layout_marginBottom="12dp" />

        <!-- Descrição -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pontos_apoio_descricao"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- CRAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cras_titulo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cras_descricao"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnCras"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/cras_botao"
                android:backgroundTint="@color/blue_primary"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- CREAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creas_titulo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/creas_descricao"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnCreas"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/creas_botao"
                android:backgroundTint="@color/blue_primary"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Conselho Tutelar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/conselho_tutelar_titulo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/blue_primary"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/conselho_tutelar_descricao"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnConselhoTutelar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/conselho_tutelar_botao"
                android:backgroundTint="@color/blue_primary"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voltar"
            android:backgroundTint="@color/dark_gray"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp" />

    </LinearLayout>

</ScrollView>
