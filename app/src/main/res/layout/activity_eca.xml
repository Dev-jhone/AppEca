<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_titulo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary_dark"
            android:layout_marginBottom="16dp" />

        <!-- Introdução -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_introducao"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <!-- Princípios -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_principios_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_principios"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <!-- Direitos -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_direitos_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_direitos"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <!-- Deveres -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_deveres_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_deveres"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Links -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_titulo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_descricao"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <!-- Legislação -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_legislacao_titulo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_legislacao"
            android:autoLink="web"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Órgãos -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_orgaos_titulo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_orgaos"
            android:autoLink="web"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Sistema -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_sistema_titulo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_sistema"
            android:autoLink="web"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Apoio -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_apoio_titulo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/eca_links_apoio"
            android:autoLink="web"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/voltar"
            android:backgroundTint="@color/text_secondary"
            android:textColor="@color/text_on_primary"
            android:layout_gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp" />

    </LinearLayout>

</ScrollView>
