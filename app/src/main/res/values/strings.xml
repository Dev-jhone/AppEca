    <string name="info_titulo">Informações do Aplicativo</string>
    <string name="info_descricao">
        Este aplicativo foi desenvolvido para auxiliar cidadãos, oferecendo
        informações essenciais sobre proteção, direitos e serviços de apoio.
    </string>

    <string name="info_publico_titulo">Para quem é este aplicativo?</string>
    <string name="info_publico_descricao">
        Destinado a cidadãos, responsáveis legais, educadores e profissionais
        da rede de proteção.
    </string>

